<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:RogueEssence.Dev.ViewModels;assembly=RogueEssence.Editor.Avalonia"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             xmlns:converters="clr-namespace:RogueEssence.Dev.Converters"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             x:Class="RogueEssence.Dev.Views.SpawnListViewBox">
    <Design.DataContext>
        <vm:SpawnListBoxViewModel/>
    </Design.DataContext>
    <UserControl.Resources>
        <converters:ValidIdxConverter x:Key="ValidIdxConverter"/>
        <converters:PercentConverter x:Key="PercentConverter"/>
    </UserControl.Resources>

    <DataGrid IsReadOnly="true"
              HorizontalAlignment="Stretch"
              ItemsSource="{Binding Collection}"
              SelectedIndex="{Binding CurrentElement, Mode=TwoWay}"
              Margin="4"
              MinHeight="50"
              Classes="default">
        <DataGrid.Columns>
            <DataGridTextColumn Header="Chance" Binding="{Binding Path=Chance, Converter={StaticResource PercentConverter}, Mode=OneWay}" Width="80" />
            <DataGridTextColumn Header="Value"  Binding="{Binding Path=DisplayValue}" Width="*" />
        </DataGrid.Columns>
    </DataGrid>

</UserControl>