<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:RogueEssence.Dev.ViewModels;assembly=RogueEssence.Editor.Avalonia"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="RogueEssence.Dev.Views.DevTabScript">
    <Design.DataContext>
        <vm:DevTabScriptViewModel/>
    </Design.DataContext>
    <Grid RowDefinitions="40, 26, Auto, 40" ColumnDefinitions="*, *" ColumnSpacing="8" RowSpacing="8">
                  
        <Button Classes="flat" Name="btnReloadScripts" Command="{Binding btnReloadScripts_Click}" Margin="4" Grid.Row="0" Grid.Column="0" >Reload Scripts</Button>
        <Button Classes="flat" Name="btnTextTest" Command="{Binding btnTextTest_Click}" Margin="4" Grid.Row="0" Grid.Column="1" >Text Test</Button>
        <TextBlock Margin="4,0" VerticalAlignment="Bottom" Grid.Row="1" Grid.Column="0">Lua Console:</TextBlock>
        <TextBox Name="txtScriptOutput" Height="300" VerticalAlignment="Stretch" VerticalContentAlignment="Top" Text="{Binding ScriptLog}" CaretIndex="{Binding ScriptCaret}" Margin="4" IsReadOnly="True" Grid.Row="2" Grid.ColumnSpan="2" />
        <TextBox Name="txtScriptInput" Text="{Binding ScriptLine}" CaretIndex="{Binding CmdCaret, Mode=TwoWay}" Margin="4" TextWrapping="Wrap" Grid.Row="3" Grid.ColumnSpan="2" KeyDown="txtScriptInput_KeyDown"></TextBox>
    </Grid>
</UserControl>