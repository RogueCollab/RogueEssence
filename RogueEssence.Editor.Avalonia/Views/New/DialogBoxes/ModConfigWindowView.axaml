<v:ChromelessWindow xmlns="https://github.com/avaloniaui"
                    xmlns:vm="clr-namespace:RogueEssence.Dev.ViewModels;assembly=RogueEssence.Editor.Avalonia"
                    xmlns:views="clr-namespace:RogueEssence.Dev.Views"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    xmlns:v="using:RogueEssence.Dev.Views"
                    mc:Ignorable="d"
                    x:Class="RogueEssence.Dev.Views.ModConfigWindowView"
                    Title="Mod Config" Width="420" Height="480">
    <Design.DataContext>
        <vm:ModConfigWindowViewModel />
    </Design.DataContext>
    <Grid RowDefinitions="Auto,*">
        <!-- TitleBar -->
        <Grid Grid.Row="0" Height="28" IsVisible="{Binding !#ThisControl.UseSystemWindowFrame}">
            <Border Background="{DynamicResource Brush.TitleBar}"
                    BorderThickness="0,0,0,1" BorderBrush="{DynamicResource Brush.Border0}"
                    PointerPressed="BeginMoveWindow" />

            <Path Width="14" Height="14"
                  Margin="10,0,0,0"
                  HorizontalAlignment="Left"
                  Data="{StaticResource Icons.SoftwareUpdate}"
                  IsVisible="{OnPlatform True, macOS=False}" />

            <TextBlock Classes="bold"
                       Text="{Binding Title}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       IsHitTestVisible="False" />

            <v:CaptionButtons HorizontalAlignment="Right"
                              IsCloseButtonOnly="True"
                              IsVisible="{OnPlatform True, macOS=False}" />

        </Grid>
        <Grid Grid.Row="1" Margin="4" RowDefinitions="188, *, 42">
            <Grid RowDefinitions="36, 36, 36, 80" ColumnDefinitions="72, *">
                <TextBlock Margin="4,2" Text="Name:" VerticalAlignment="Center" HorizontalAlignment="Right" />
                <Grid Grid.Row="0" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="48" />
                        <ColumnDefinition Width="72" />
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding Name}" VerticalAlignment="Center" Margin="4" />
                    <TextBlock Margin="4,2" Text="Type:" VerticalAlignment="Center" HorizontalAlignment="Right"
                               Grid.Column="1" />
                    <views:SearchComboBox Margin="4,2" ItemsSource="{Binding ModTypes}"
                                          SelectedIndex="{Binding ChosenModType}" Grid.Column="2" />
                </Grid>

                <TextBlock Margin="4,2" Text="Namespace:" VerticalAlignment="Center" HorizontalAlignment="Right"
                           Grid.Row="1" />
                <Grid Grid.Row="1" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="48" />
                        <ColumnDefinition Width="72" />
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding Namespace}" VerticalAlignment="Center" Margin="4" />
                    <TextBlock Margin="4,2" Text="Version:" VerticalAlignment="Center" HorizontalAlignment="Right"
                               Grid.Column="1" />
                    <TextBox Text="{Binding Version}" VerticalAlignment="Center" Margin="4" Grid.Column="2" />
                </Grid>

                <TextBlock Margin="4,2" Text="Author:" VerticalAlignment="Center" HorizontalAlignment="Right"
                           Grid.Row="2" />
                <TextBox Text="{Binding Author}" VerticalAlignment="Center" Margin="4" Grid.Row="2" Grid.Column="1" />
                <TextBlock Margin="4,2" Text="Description:" VerticalAlignment="Top" HorizontalAlignment="Right"
                           Grid.Row="3" />
                <TextBox Text="{Binding Description}" AcceptsReturn="True" Margin="4" Grid.Row="3" Grid.Column="1" />
            </Grid>

            <Expander Grid.Row="1">
                <Expander.Header>
                    <Label Content="Advanced"></Label>
                </Expander.Header>
                <Grid RowDefinitions="36, 36, *" ColumnDefinitions="80, *">
                    <TextBlock Margin="4,2" Text="UUID:" VerticalAlignment="Center" HorizontalAlignment="Right"
                               Grid.Row="0" />
                    <Grid Grid.Row="0" Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="64" />
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding UUID}" IsReadOnly="True" VerticalAlignment="Center" Margin="4" />
                        <Button Command="{Binding btnRegenUUID_Click}" Margin="4" Grid.Column="1">Regen</Button>
                    </Grid>

                    <TextBlock Margin="4,2" Text="Game Version:" VerticalAlignment="Center" HorizontalAlignment="Right"
                               Grid.Row="1" />
                    <TextBox Text="{Binding GameVersion}" VerticalAlignment="Center" Margin="4" Grid.Row="1"
                             Grid.Column="1" />

                    <TextBlock Margin="4" VerticalAlignment="Top" HorizontalAlignment="Right" Grid.Row="2">Relations:</TextBlock>
                    <views:CollectionBox DataContext="{Binding Relationships}" Margin="4" Grid.Row="2" Grid.Column="1" />

                </Grid>
            </Expander>
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Button Click="btnOK_Click" Margin="4" Grid.Column="0">OK</Button>
                <Button Click="btnCancel_Click" Margin="4" Grid.Column="1">Cancel</Button>
            </Grid>
        </Grid>
    </Grid>
</v:ChromelessWindow>