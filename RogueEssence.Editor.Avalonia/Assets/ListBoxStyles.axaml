<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:s="using:RogueEssence.Dev">

    <Styles.Resources>
        <ControlTheme x:Key="CompactListBoxItem" TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
            <Setter Property="Padding" Value="4,2"/>
        </ControlTheme>
    </Styles.Resources>

</Styles>